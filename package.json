{
  "name": "archivist",
  "version": "0.2.0",
  "description": "D&D 5e/2024 toolkit with an AI agent that generates monsters, spells, items, encounters, and NPCs. Renders parchment stat blocks, inline dice tags, and includes a full SRD compendium.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run build:css && node esbuild.config.mjs production",
    "build:css": "node scripts/build-css.mjs",
    "test": "vitest run --exclude 'tests/inquiry/**'",
    "test:watch": "vitest --exclude 'tests/inquiry/**'"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
