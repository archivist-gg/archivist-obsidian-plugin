{
  "name": "archivist-gg",
  "version": "0.2.1",
  "description": "D&D 5e/2024 toolkit for Obsidian: parchment stat blocks from YAML, inline dice tags, a full SRD compendium, homebrew compendiums, and player-character sheets.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npm run build:css && node esbuild.config.mjs production",
    "build:css": "node scripts/build-css.mjs",
    "lint": "eslint 'packages/obsidian/src/**/*.ts'",
    "lint:fix": "eslint 'packages/obsidian/src/**/*.ts' --fix",
    "test": "vitest run",
    "check": "npm run typecheck && npm run lint && npm run test",
    "typecheck": "tsc -b --force",
    "test:watch": "vitest",
    "migrate-formula-tags": "tsx scripts/migrate-formula-tags.ts"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [],
  "author": "Shinoobi",
  "license": "AGPL-3.0",
  "devDependencies": {
    "@codemirror/language": "^6.12.3",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@tabler/icons": "^3.41.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.27.1",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-obsidianmd": "^0.2.4",
    "jest": "^29.7.0",
    "jsdom": "^29.0.2",
    "obsidian": "latest",
    "ts-jest": "^29.1.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.38.6",
    "js-yaml": "^4.1.0",
    "monkey-around": "^3.0.0",
    "tslib": "^2.7.0",
    "zod": "^4.3.6"
  }
}
