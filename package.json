    "@codemirror/language": "^6.12.3",
    "@tabler/icons": "^3.41.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.27.1",
    "jest": "^29.7.0",
    "jsdom": "^29.0.2",
    "obsidian": "latest",
    "ts-jest": "^29.1.2",
    "typescript": "^5.6.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.86",
    "@modelcontextprotocol/sdk": "~1.25.3",
